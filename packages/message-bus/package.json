{
  "name": "@xolvio/message-bus",
  "publishConfig": {
    "access": "public"
  },
  "description": "Message bus for handling commands, events, and queries",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && tsx ../../scripts/fix-esm-imports.ts",
    "clean": "rm -rf dist",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "link:dev": "pnpm build && pnpm link --global",
    "unlink:dev": "pnpm unlink --global",
    "release": "pnpm publish --no-git-checks"
  },
  "keywords": [
    "message-bus",
    "event-driven",
    "cqrs"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "debug": "^4.4.1"
  },
  "version": "1.148.0"
}
