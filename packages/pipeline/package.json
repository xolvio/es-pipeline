{
  "name": "@xolvio/pipeline",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && tsx ../../scripts/fix-esm-imports.ts",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --reporter=dot --coverage --coverage.reporter=text",
    "test:e2e": "vitest run --reporter=dot --include 'src/**/*.e2e.specs.ts'",
    "type-check": "tsc --noEmit",
    "e2e:kanban": "tsx scripts/run-kanban-e2e.ts",
    "serve": "tsx --watch scripts/start-server.ts",
    "release": "pnpm publish --no-git-checks"
  },
  "dependencies": {
    "@xolvio/file-store": "workspace:*",
    "@xolvio/message-bus": "workspace:*",
    "@event-driven-io/dumbo": "0.13.0-beta.31",
    "@event-driven-io/emmett": "0.43.0-beta.5",
    "@event-driven-io/emmett-sqlite": "0.43.0-beta.5",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "get-port": "^7.1.0",
    "jose": "^5.9.6",
    "nanoid": "^5.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "version": "1.148.0"
}
